# VoltFlow Production Environment Variables
# Copy this to .env and fill in all required values before deploying

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=voltflow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── Backend ───────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_RANDOM_STRING

# ── Dashboard (used at build time by Dockerfile) ──────────────────────────────
VITE_API_URL=https://api.yourdomain.com

# ── TLS (optional — mount certificate files and set paths) ───────────────────
# TLS_KEY_PATH=/certs/server.key
# TLS_CERT_PATH=/certs/server.crt
